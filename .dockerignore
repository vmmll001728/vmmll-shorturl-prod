# Git
.git
.gitignore

# 环境变量（包含密钥）
.env
.env.*

# 测试文件（不需要在生产镜像中）
tests/
test_data/
.pytest_cache/

# Python 缓存
__pycache__/
*.pyc
*.pyo

# 本地开发配置
venv/
.venv/
node_modules/

# IDE 配置
.vscode/
.idea/
*.swp

# 文档（不需要在运行时）
docs/
*.md
LICENSE

# CI/CD（不需要在镜像中）
.github/
ci_local.sh

# 覆盖文件
docker-compose*.yml
